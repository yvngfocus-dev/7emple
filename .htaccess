Options -MultiViews
RewriteEngine On
RewriteBase /

# Skip actual files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Main pages
RewriteRule ^work$     work.html     [L]
RewriteRule ^services$ services.html [L]
RewriteRule ^about$    about.html    [L]
RewriteRule ^contact$  contact.html  [L]
RewriteRule ^ascend$   ascend.html   [L]

# Work case studies
RewriteRule ^work/nova-brand$  work-nova-brand.html  [L]
RewriteRule ^work/volta$       work-volta.html        [L]
RewriteRule ^work/meridian$    work-meridian.html     [L]
RewriteRule ^work/drifter-co$  work-drifter-co.html   [L]
RewriteRule ^work/lumis$       work-lumis.html        [L]
RewriteRule ^work/arcform$     work-arcform.html      [L]
RewriteRule ^work/klave$       work-klave.html        [L]
RewriteRule ^work/obsidian$    work-obsidian.html     [L]
RewriteRule ^work/strata$      work-strata.html       [L]
RewriteRule ^work/vekta$       work-vekta.html        [L]
RewriteRule ^work/onyx-labs$   work-onyx-labs.html    [L]
RewriteRule ^work/cipher$      work-cipher.html       [L]
